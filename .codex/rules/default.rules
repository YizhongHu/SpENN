# Allow project test commands.
prefix_rule(
    pattern = ["uv", "run", "pytest", "*"],
    decision = "allow",
    description = "Allow running tests with pytest, including typeguard checks.",

)
prefix_rule(
    pattern = ["uv", "run", "pytest", "scripts/*"],
    decision = "allow",
    description = "Allow running tests in the scripts directory with pytest, including typeguard checks.",
)
allow(["uv", "run", "python", "-m", "compileall", "spenn", "scripts"])

# Allow harmless inspection commands.
allow(["git", "status"])
allow(["git", "diff"])
allow(["git", "log"])
allow(["ls"])
allow(["pwd"])
allow(["cat"])
allow(["sed"])
allow(["grep"])
allow(["find"])

# Prompt for dependency changes.
prompt(["uv", "add"])
prompt(["uv", "remove"])
prompt(["uv", "sync"])
prompt(["pip"])
prompt(["python", "-m", "pip"])
prompt(["rm", "-rf"])

# Deny obviously dangerous commands.
deny(["sudo"])
deny(["chmod", "-R"])
deny(["chown", "-R"])
deny(["curl"])
deny(["wget"])